{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "allowJs": true,
    "checkJs": false,
    "declaration": false,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": ["controller-server.ts", "controller-server.js", "agent.mjs", "*.ts"],
  "exclude": ["node_modules", "dist", "tests", "scripts"]
}
